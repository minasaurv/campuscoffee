<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/appTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_title"
        android:textSize="40sp"
        android:textAlignment="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/name_for_order"
            android:labelFor="@+id/nameForOrder"/>
        <EditText
            android:id="@+id/nameForOrder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:hint="@string/john_doe"/>

        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RadioButton
                android:id="@+id/espressoButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/espresso"/>
            <RadioButton
                android:id="@+id/vanillaLatteButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/vanilla_latte"/>
            <RadioButton
                android:id="@+id/caramelLatteButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/caramel_latte"/>
        </RadioGroup>

</LinearLayout>